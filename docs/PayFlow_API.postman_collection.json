		{
			"name": "Auth",
			"item": [
				{
					"name": "Register Business",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201 || pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.business && jsonData.business.id) {",
									"        pm.collectionVariables.set(\"business_id\", jsonData.business.id);",
									"        console.log(\"Saved business_id: \" + jsonData.business.id);",
									"    } else if (jsonData.data && jsonData.data.id) {",
									"        pm.collectionVariables.set(\"business_id\", jsonData.data.id);",
									"        console.log(\"Saved business_id: \" + jsonData.data.id);",
									"    } else if (jsonData.id) {",
									"        pm.collectionVariables.set(\"business_id\", jsonData.id);",
									"        console.log(\"Saved business_id: \" + jsonData.id);",
									"    }",
									"    if (jsonData.token) {",
									"        pm.collectionVariables.set(\"token\", jsonData.token);",
									"        console.log(\"Saved token from register response\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"business_name\": \"Acme Corp\",\n  \"email\": \"admin@acmecorp.com\",\n  \"password\": \"SecurePass123\",\n  \"rc_number\": \"RC123456\",\n  \"incorporation_date\": \"2020-01-15T00:00:00Z\",\n  \"director_bvn\": \"12345678901\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/register",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "register"]
						},
						"description": "Register a new business account. Creates a business entity and an admin user. No authentication required."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.token) {",
									"        pm.collectionVariables.set(\"token\", jsonData.token);",
									"        console.log(\"Token saved successfully\");",
									"    } else if (jsonData.data && jsonData.data.token) {",
									"        pm.collectionVariables.set(\"token\", jsonData.data.token);",
									"        console.log(\"Token saved successfully from data.token\");",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@acmecorp.com\",\n  \"password\": \"SecurePass123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/auth/login",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "login"]
						},
						"description": "Authenticate with email and password. Returns a JWT token that is automatically saved to the collection variable for use in subsequent requests."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints for business registration and login."
