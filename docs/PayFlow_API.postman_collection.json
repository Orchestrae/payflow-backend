						"url": { "raw": "{{base_url}}/v1/cadres", "host": ["{{base_url}}"], "path": ["v1", "cadres"] },
						"description": "List all cadres for the business."
					}
				},
				{
					"name": "Get Cadre",
					"request": {
						"method": "GET",
						"header": [],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"url": { "raw": "{{base_url}}/v1/cadres/{{cadre_id}}", "host": ["{{base_url}}"], "path": ["v1", "cadres", "{{cadre_id}}"] },
						"description": "Retrieve a single cadre by ID, including its earning components and deduction rules."
					}
				},
				{
					"name": "Update Cadre",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Senior Engineer\",\n  \"earning_components\": [\n    { \"name\": \"Basic Salary\", \"amount\": 20000000, \"component_type\": \"basic\" },\n    { \"name\": \"Housing Allowance\", \"amount\": 5000000, \"component_type\": \"housing\" },\n    { \"name\": \"Transport Allowance\", \"amount\": 3000000, \"component_type\": \"transport\" }\n  ]\n}"
						},
						"url": { "raw": "{{base_url}}/v1/cadres/{{cadre_id}}", "host": ["{{base_url}}"], "path": ["v1", "cadres", "{{cadre_id}}"] },
