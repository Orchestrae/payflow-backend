						"url": { "raw": "{{base_url}}/v1/deduction-rules", "host": ["{{base_url}}"], "path": ["v1", "deduction-rules"] },
						"description": "List all deduction rules for the business."
					}
				},
				{
					"name": "Update Deduction Rule",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
