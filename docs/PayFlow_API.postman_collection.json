						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"business_name\": \"Acme Ltd\",\n  \"email\": \"admin@acme.com\",\n  \"password\": \"securePass123\",\n  \"rc_number\": \"RC123456\",\n  \"incorporation_date\": \"2020-01-15T00:00:00Z\",\n  \"director_bvn\": \"12345678901\"\n}"
