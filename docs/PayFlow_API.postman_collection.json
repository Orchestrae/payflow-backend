		{
			"name": "Payroll Runs",
			"item": [
				{
					"name": "Create Payroll Run",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"period\": \"2026-01\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/payroll-runs", "host": ["{{base_url}}"], "path": ["v1", "payroll-runs"] },
						"description": "Create a new payroll run for the given period (YYYY-MM). Calculates gross pay, deductions, and net pay for all active employees."
					}
				},
				{
					"name": "List Payroll Runs",
					"request": {
						"method": "GET",
						"header": [],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"url": { "raw": "{{base_url}}/v1/payroll-runs", "host": ["{{base_url}}"], "path": ["v1", "payroll-runs"] },
						"description": "List all payroll runs for the business."
					}
				},
				{
					"name": "Get Payroll Run",
					"request": {
						"method": "GET",
						"header": [],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"url": { "raw": "{{base_url}}/v1/payroll-runs/{{payroll_run_id}}", "host": ["{{base_url}}"], "path": ["v1", "payroll-runs", "{{payroll_run_id}}"] },
						"description": "Retrieve a single payroll run by ID, including all payslip line items."
					}
				},
				{
					"name": "Submit Payroll Run",
					"request": {
						"method": "POST",
						"header": [],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"url": { "raw": "{{base_url}}/v1/payroll-runs/{{payroll_run_id}}/submit", "host": ["{{base_url}}"], "path": ["v1", "payroll-runs", "{{payroll_run_id}}", "submit"] },
						"description": "Submit a draft payroll run for approval. Moves status from draft to pending_approval."
					}
				},
				{
					"name": "Approve Payroll Run",
					"request": {
						"method": "POST",
						"header": [],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"url": { "raw": "{{base_url}}/v1/payroll-runs/{{payroll_run_id}}/approve", "host": ["{{base_url}}"], "path": ["v1", "payroll-runs", "{{payroll_run_id}}", "approve"] },
						"description": "Approve a submitted payroll run. Moves status from pending_approval to approved."
					}
				},
				{
					"name": "Reject Payroll Run",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reason\": \"Incorrect figures\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/payroll-runs/{{payroll_run_id}}/reject", "host": ["{{base_url}}"], "path": ["v1", "payroll-runs", "{{payroll_run_id}}", "reject"] },
						"description": "Reject a submitted payroll run with a reason. Moves status back to draft."
					}
				},
				{
					"name": "Process Payroll Now",
					"request": {
						"method": "POST",
						"header": [],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"url": { "raw": "{{base_url}}/v1/payroll-runs/{{payroll_run_id}}/process-now", "host": ["{{base_url}}"], "path": ["v1", "payroll-runs", "{{payroll_run_id}}", "process-now"] },
						"description": "Trigger immediate disbursement of an approved payroll run. Initiates bank transfers for all employees."
					}
				}
			]
		},
