				},
				{
					"name": "Deactivate Employee",
					"request": {
						"method": "PATCH",
						"header": [],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"url": { "raw": "{{base_url}}/v1/employees/{{employee_id}}/deactivate", "host": ["{{base_url}}"], "path": ["v1", "employees", "{{employee_id}}", "deactivate"] },
						"description": "Deactivate an employee. They will be excluded from future payroll runs."
