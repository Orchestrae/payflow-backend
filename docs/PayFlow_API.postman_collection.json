				{
					"name": "Delete Deduction Rule",
					"request": {
						"method": "DELETE",
						"header": [],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"url": { "raw": "{{base_url}}/v1/deduction-rules/{{deduction_rule_id}}", "host": ["{{base_url}}"], "path": ["v1", "deduction-rules", "{{deduction_rule_id}}"] },
						"description": "Delete a deduction rule by ID. Admin only."
					}
				}
			]
		},
		{
			"name": "Cadres",
			"item": [
				{
					"name": "Create Cadre",
