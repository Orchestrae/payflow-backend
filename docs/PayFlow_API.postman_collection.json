						"url": { "raw": "{{base_url}}/v1/business/settings", "host": ["{{base_url}}"], "path": ["v1", "business", "settings"] },
						"description": "Update business settings. Admin only. Controls which statutory deductions are active."
					}
				}
			]
		},
		{
			"name": "Dashboard",
			"item": [
				{
					"name": "Get Dashboard",
					"request": {
						"method": "GET",
						"header": [],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"url": { "raw": "{{base_url}}/v1/dashboard", "host": ["{{base_url}}"], "path": ["v1", "dashboard"] },
						"description": "Retrieve the dashboard summary including employee count, payroll totals, and recent activity."
					}
				}
			]
		},
		{
			"name": "Deduction Rules",
			"item": [
				{
					"name": "Create Deduction Rule",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Custom Tax\",\n  \"type\": \"percentage\",\n  \"value\": 5.0,\n  \"calculation_basis\": \"gross_pay\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/deduction-rules", "host": ["{{base_url}}"], "path": ["v1", "deduction-rules"] },
						"description": "Create a custom deduction rule. Admin only. Types: percentage, fixed_amount. Calculation basis: gross_pay, basic_pay, net_pay."
					}
				},
				{
					"name": "List Deduction Rules",
					"request": {
						"method": "GET",
						"header": [],
