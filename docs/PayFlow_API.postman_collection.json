{
	"info": {
		"_postman_id": "payflow-api-collection",
		"name": "PayFlow API",
		"description": "PayFlow — Nigerian Payroll SaaS API. Covers authentication, employee management, payroll runs, wallet operations, transfers, and statutory compliance reports.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8080" },
		{ "key": "token", "value": "" },
		{ "key": "employee_id", "value": "" },
		{ "key": "cadre_id", "value": "" },
		{ "key": "payroll_run_id", "value": "" },
		{ "key": "deduction_rule_id", "value": "" },
		{ "key": "transfer_id", "value": "" },
		{ "key": "account_holder_reference", "value": "" }
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] },
						"description": "Returns the overall health status of the PayFlow API."
					}
				},
				{
					"name": "Liveness Probe",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{base_url}}/health/live", "host": ["{{base_url}}"], "path": ["health", "live"] },
						"description": "Lightweight liveness probe for container orchestrators."
					}
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"business_name\": \"Acme Corp\",\n  \"email\": \"admin@acme.com\",\n  \"password\": \"password123\",\n  \"rc_number\": \"RC123456\",\n  \"incorporation_date\": \"2020-01-15T00:00:00Z\",\n  \"director_bvn\": \"12345678901\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/auth/register", "host": ["{{base_url}}"], "path": ["v1", "auth", "register"] },
						"description": "Register a new business and admin user account."
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.collectionVariables.set(\"token\", pm.response.json().token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/auth/login", "host": ["{{base_url}}"], "path": ["v1", "auth", "login"] },
						"description": "Authenticate and receive a JWT token. The token is automatically saved to the collection variable."
					}
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@acme.com\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/auth/forgot-password", "host": ["{{base_url}}"], "path": ["v1", "auth", "forgot-password"] },
						"description": "Request a password reset email."
					}
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"paste-reset-token\",\n  \"new_password\": \"newpassword123\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/auth/reset-password", "host": ["{{base_url}}"], "path": ["v1", "auth", "reset-password"] },
						"description": "Reset the password using a token received via email."
					}
				},
				{
					"name": "Accept Invitation",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"paste-invite-token\",\n  \"password\": \"mypassword123\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/auth/accept-invitation", "host": ["{{base_url}}"], "path": ["v1", "auth", "accept-invitation"] },
						"description": "Accept a team invitation and set a password for the new user account."
					}
				}
			]
		},
		{
			"name": "User Management",
			"item": [
				{
					"name": "Invite User",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"operator@acme.com\",\n  \"role\": \"operator\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/auth/invite", "host": ["{{base_url}}"], "path": ["v1", "auth", "invite"] },
						"description": "Invite a new user to the business. Admin only. Supported roles: admin, operator, viewer."
					}
				}
			]
		},
