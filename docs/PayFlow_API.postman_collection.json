						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Updated Tax\",\n  \"type\": \"percentage\",\n  \"value\": 7.5,\n  \"calculation_basis\": \"gross_pay\"\n}"
						},
						"url": { "raw": "{{base_url}}/v1/deduction-rules/{{deduction_rule_id}}", "host": ["{{base_url}}"], "path": ["v1", "deduction-rules", "{{deduction_rule_id}}"] },
						"description": "Update an existing deduction rule by ID. Admin only."
					}
