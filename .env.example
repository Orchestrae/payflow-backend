# =============================================================================
# PayFlow Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- REQUIRED ---
JWT_SECRET=your-secret-key-minimum-32-characters-long
DB_URL=postgres://payflow_user:payflow_secret@localhost:5433/payflow_db?sslmode=disable

# --- SERVER ---
SERVER_PORT=8080
LOG_LEVEL=debug
LOG_PRETTY=true

# --- PAYMENT PROVIDERS ---
# Enable providers: korapay,paystack,vfd (comma-separated)
ENABLED_PROVIDERS=korapay,paystack
TRANSFER_DEFAULT_PROVIDER=paystack
TRANSFER_PROVIDER_FALLBACK_ORDER=korapay

# Paystack (recommended for production)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_BASE_URL=https://api.paystack.co

# Korapay
KORAPAY_API_KEY=sk_test_your_korapay_api_key
KORAPAY_PUBLIC_KEY=pk_test_your_korapay_public_key
KORAPAY_BASE_URL=https://api.korapay.com

# VFD Bank (optional)
VFD_CONSUMER_KEY=
VFD_CONSUMER_SECRET=
VFD_BASE_URL=https://api-devapps.vfdbank.systems
VFD_WEBHOOK_SECRET=

# --- TRANSFER LIMITS (kobo) ---
TRANSFER_MIN_AMOUNT=1000
TRANSFER_MAX_AMOUNT=10000000

# --- EMAIL (SMTP) ---
# Local dev: MailHog (docker-compose defaults)
# Production: Brevo (free 300/day), SendGrid, or any SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@payflow.com

# --- APPLICATION ---
APP_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- REDIS (optional) ---
REDIS_URL=redis://localhost:6379/0

# --- DATABASE MIGRATION ---
# ENABLE_AUTO_MIGRATION=false  # Auto-enabled on Railway
