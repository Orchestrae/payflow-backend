# .env.example

# Server Configuration
SERVER_PORT=8080
LOG_LEVEL=debug # Use "info" in production
LOG_PRETTY=true # Use "false" for JSON logs in production

# Database Configuration (PostgreSQL)
# Example DSN: postgres://user:password@host:port/dbname?sslmode=disable
DB_URL="postgres://payflow_user:payflow_secret@localhost:5432/payflow_db?sslmode=disable"

# Security Configuration
JWT_SECRET="a-very-secret-and-strong-key-that-is-at-least-32-chars-long"
JWT_EXPIRATION_HOURS=72

# External Services
KORAPAY_API_KEY=""
KORAPAY_PUBLIC_KEY=""
KORAPAY_BASE_URL="https://api.korapay.com/v1" # Use sandbox URL for dev

VFD_CONSUMER_KEY="" // Replace with your VFD consumer key
VFD_CONSUMER_SECRET="" // Replace with your VFD consumer secret
VFD_TEST_BASE_URL="https://api-devapps.vfdbank.systems/vfd-tech/baas-portal/v1.1/baasauth/token"
VFD_PROD_BASE_URL="https://api-apps.vfdbank.systems/vfd-tech/baas-portal/v1.1/baasauth/token"